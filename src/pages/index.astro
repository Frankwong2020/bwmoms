---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import recentStatic from '../data/recent.json';

type Block = { title: string; items: string[] };
const staticBlocks = recentStatic as Block[];
---

<Base title="桥水小娃群 · 最近活动">
  <Header activeTab="home" />
  <Hero />

  <main class="max-w-6xl mx-auto px-6 pb-16 space-y-10">
    <!-- === 本周活动 === -->
    <section>
      <div class="flex items-baseline justify-between gap-2 mb-4 flex-wrap">
        <h2 class="text-xl font-serif font-bold text-ink flex items-baseline gap-2">
          <span>🎈 本周活动</span>
          <span id="events-count" class="text-sm text-ink-muted font-sans"></span>
        </h2>
        <button
          type="button"
          data-create-item
          data-item-type="event"
          class="text-sm px-3 py-1.5 rounded-chip bg-sage text-white hover:bg-sage-dark font-medium whitespace-nowrap"
        >
          + 发布活动
        </button>
      </div>
      <div id="events-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <p class="text-sm text-ink-muted col-span-full py-6 text-center">加载活动中…</p>
      </div>
    </section>

    <!-- === 最近新增地点 === -->
    <section>
      <h2 class="text-xl font-serif font-bold text-ink mb-4 flex items-baseline gap-2">
        <span>🆕 最近新增</span>
        <span id="new-items-count" class="text-sm text-ink-muted font-sans"></span>
      </h2>
      <div id="new-items-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <p class="text-sm text-ink-muted col-span-full py-4 text-center">加载中…</p>
      </div>
    </section>

    <!-- === 最近热议 === -->
    <section>
      <h2 class="text-xl font-serif font-bold text-ink mb-4 flex items-baseline gap-2">
        <span>💬 最近热议</span>
      </h2>
      <div id="hot-items-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <p class="text-sm text-ink-muted col-span-full py-4 text-center">加载中…</p>
      </div>
    </section>

    <!-- === 季节性 / 理财提醒 (static) === -->
    {staticBlocks.length > 0 && (
      <section>
        <h2 class="text-xl font-serif font-bold text-ink mb-4 flex items-baseline gap-2">
          <span>📅 季节推荐</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {staticBlocks.map((b) => (
            <article class="bg-white rounded-card shadow-soft p-5">
              {b.title && <h3 class="font-serif font-bold text-base mb-2">{b.title}</h3>}
              <ul class="space-y-1.5 text-sm text-ink-light">
                {b.items.slice(0, 6).map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>
    )}
  </main>

  <!-- Modals reused by create/edit/history/flag -->
</Base>

<script>
  import '../lib/feedback';
  import '../lib/hydrate-items';
  import '../lib/edit-item';
  import '../lib/history';
  import '../lib/flag';
  import '../lib/share';
  import '../lib/deep-link';
  import '../lib/home-aggregator';
</script>
