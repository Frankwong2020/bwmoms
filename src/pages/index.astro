---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import playData from '../data/play.json';

type Play = {
  id: string;
  num: number;
  name: string;
  drive: string;
  price: string;
  tips: string;
  section: string;
};
const play = playData as Play[];

const sections = [...new Set(play.map((p) => p.section))];

// Infer a quick "vibe" per entry for filtering
function vibe(p: Play) {
  const s = (p.name + ' ' + p.tips).toLowerCase();
  if (/trampoline|bowl|arcade|kid|indoor|gym|climb|museum|博物|图书/i.test(s)) return 'indoor';
  if (/beach|海|滩/i.test(s)) return 'beach';
  if (/zoo|aquarium|safari|park|park,|park$|公园|植物|garden|farm|农|pick/i.test(s)) return 'outdoor';
  if (/pool|swim|water|泳/i.test(s)) return 'water';
  return 'other';
}

function mapLink(name: string) {
  const q = encodeURIComponent(name);
  return `https://www.google.com/maps/search/?api=1&query=${q}`;
}

const mainList = play.filter((p) => p.section === '遛娃圣地');
const otherSections = sections.filter((s) => s !== '遛娃圣地');
---

<Base>
  <Header activeTab="play" />
  <Hero />

  <main class="max-w-6xl mx-auto px-6 pb-16">
    <!-- Filter chips -->
    <div class="flex gap-2 overflow-x-auto scrollbar-none mb-6 -mx-6 px-6 pb-2">
      <button class="filter-chip on" data-filter="all">全部 <span class="text-xs opacity-70">{mainList.length}</span></button>
      <button class="filter-chip" data-filter="indoor">🏠 室内</button>
      <button class="filter-chip" data-filter="outdoor">🌳 户外公园</button>
      <button class="filter-chip" data-filter="water">💧 水上</button>
      <button class="filter-chip" data-filter="beach">🏖️ 海滩</button>
      <button class="filter-chip" data-filter="other">✨ 其他</button>
    </div>

    <!-- Main list -->
    <section>
      <h2 class="text-xl font-serif font-bold mb-4 text-ink flex items-baseline gap-2">
        <span>🎈 遛娃圣地</span>
        <span class="text-sm text-ink-muted font-sans">{mainList.length} 个地点</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="play-grid">
        {mainList.map((p) => (
          <article class="play-card bg-white rounded-card shadow-soft p-5 hover:shadow-hover transition cursor-pointer" data-vibe={vibe(p)}>
            <div class="flex items-start justify-between gap-2 mb-2">
              <h3 class="font-semibold text-ink leading-tight flex-1">{p.name}</h3>
              <span class="text-xs text-ink-muted shrink-0">#{p.num}</span>
            </div>
            <div class="flex flex-wrap gap-2 mt-3 mb-3">
              {p.drive && <span class="tag">🚗 {p.drive}</span>}
              {p.price && <span class="tag tag-warm">{p.price}</span>}
            </div>
            {p.tips && (
              <p class="text-sm text-ink-light mt-2 leading-relaxed">{p.tips}</p>
            )}
            <a href={mapLink(p.name)} target="_blank" rel="noopener" class="text-xs text-sage-dark hover:text-sage font-medium mt-3 inline-flex items-center gap-1">
              <span>📍 Google Maps</span>
            </a>
          </article>
        ))}
      </div>
    </section>

    <!-- Other sections -->
    {otherSections.map((sec) => {
      const items = play.filter((p) => p.section === sec);
      return (
        <section class="mt-14">
          <h2 class="text-xl font-serif font-bold mb-4">🍁 {sec}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {items.map((p) => (
              <article class="bg-white rounded-card shadow-soft p-5">
                <h3 class="font-semibold text-ink leading-tight">{p.name}</h3>
                <div class="flex flex-wrap gap-2 mt-2 mb-2">
                  {p.drive && <span class="tag">🚗 {p.drive}</span>}
                  {p.price && <span class="tag tag-warm">{p.price}</span>}
                </div>
                {p.tips && (
                  <p class="text-sm text-ink-light leading-relaxed">{p.tips}</p>
                )}
                <a href={mapLink(p.name)} target="_blank" rel="noopener" class="text-xs text-sage-dark hover:text-sage font-medium mt-2 inline-flex items-center gap-1">
                  <span>📍 Google Maps</span>
                </a>
              </article>
            ))}
          </div>
        </section>
      );
    })}
  </main>
</Base>

<style>
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { scrollbar-width: none; }

  .filter-chip {
    @apply flex-shrink-0 px-4 py-2 rounded-chip text-sm font-medium whitespace-nowrap transition border border-transparent cursor-pointer;
    @apply bg-white text-ink-light hover:bg-sage-light;
  }
  .filter-chip.on {
    @apply bg-sage text-white shadow-soft;
  }

  .tag {
    @apply inline-flex items-center px-2.5 py-1 rounded-full bg-sage-light text-sage-dark text-xs font-medium;
  }
  .tag-warm {
    @apply bg-warm-light text-warm;
  }
</style>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
  const cards = document.querySelectorAll<HTMLElement>('#play-grid .play-card');
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.remove('on'));
      chip.classList.add('on');
      const f = chip.dataset.filter;
      cards.forEach((card) => {
        card.style.display = f === 'all' || card.dataset.vibe === f ? '' : 'none';
      });
    });
  });
</script>
