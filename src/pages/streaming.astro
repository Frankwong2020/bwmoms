---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import data from '../data/streaming.json';

type Site = { url: string; domain: string };
const sites = data as Site[];
---

<Base title="影视网站 · 桥水小娃群">
  <Header activeTab="streaming" />

  <section class="max-w-6xl mx-auto px-6 pt-10 pb-6">
    <h1 class="text-3xl md:text-4xl font-serif font-bold">📺 看电视电影网站</h1>
    <p class="text-ink-light mt-2">群友分享的中文影视资源</p>
  </section>

  <main class="max-w-4xl mx-auto px-6 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {sites.map((s) => (
        <a
          href={s.url}
          target="_blank"
          rel="noopener"
          class="bg-white rounded-card shadow-soft p-5 hover:shadow-hover transition flex items-center gap-3"
        >
          <span class="text-2xl">🎬</span>
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-ink">{s.domain}</div>
            <div class="text-xs text-ink-muted truncate">{s.url}</div>
          </div>
          <span class="text-ink-muted">→</span>
        </a>
      ))}
    </div>
  </main>
</Base>
