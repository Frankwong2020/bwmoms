---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import ItemFeedback from '../components/ItemFeedback.astro';
import ItemActions from '../components/ItemActions.astro';
import data from '../data/classes.json';

type Klass = {
  id: string;
  category: string;
  org: string;
  location: string;
  time: string;
  price: string;
  link: string;
};
const classes = data as Klass[];
const categories = [...new Set(classes.map((c) => c.category).filter(Boolean))];
---

<Base title="课外班推荐 · 桥水小娃群">
  <Header activeTab="classes" />

  <section class="max-w-6xl mx-auto px-6 pt-10 pb-6">
    <h1 class="text-3xl md:text-4xl font-serif font-bold">🎨 课外班推荐</h1>
    <p class="text-ink-light mt-2">网球、乒乓球、游泳等社区课程信息</p>
  </section>

  <main class="max-w-6xl mx-auto px-6 pb-16">
    <div class="flex gap-2 overflow-x-auto scrollbar-none mb-6 pb-2">
      <button class="filter-chip on" data-filter="all">全部 ({classes.length})</button>
      {categories.map((cat) => (
        <button class="filter-chip" data-filter={cat}>{cat}</button>
      ))}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="class-grid">
      {classes.map((c) => (
        <article
          class="class-card bg-white rounded-card shadow-soft p-5"
          data-item-card
          data-item-type="class"
          data-item-id={c.id}
          data-cat={c.category}
        >
          <div class="flex items-baseline justify-between gap-2 mb-2">
            <span class="tag" data-field="category">{c.category}</span>
          </div>
          <h3 class="font-semibold text-ink leading-tight mb-2" data-field="org">{c.org}</h3>
          <p class:list={['text-sm text-ink-light', { 'hidden': !c.location }]}>📍 <span data-field="location">{c.location}</span></p>
          <p class:list={['text-sm text-ink-light mt-1', { 'hidden': !c.time }]}>📅 <span data-field="time">{c.time}</span></p>
          <p class:list={['text-sm text-warm mt-1 font-medium', { 'hidden': !c.price }]}>💵 <span data-field="price">{c.price}</span></p>
          {c.link && (
            <a href={c.link} target="_blank" rel="noopener" class="text-xs text-sage-dark hover:text-sage font-medium mt-3 inline-block">
              🔗 报名链接
            </a>
          )}
          <ItemActions itemType="class" itemId={c.id} />
          <ItemFeedback itemType="class" itemId={c.id} />
        </article>
      ))}
    </div>
  </main>
</Base>

<script>
  import '../lib/feedback';
  import '../lib/hydrate-items';
  import '../lib/edit-item';
  import '../lib/history';
  import '../lib/flag';
</script>

<style>
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { scrollbar-width: none; }
  .filter-chip {
    @apply flex-shrink-0 px-4 py-2 rounded-chip text-sm font-medium whitespace-nowrap transition cursor-pointer;
    @apply bg-white text-ink-light hover:bg-sage-light;
  }
  .filter-chip.on {
    @apply bg-sage text-white shadow-soft;
  }
  .tag {
    @apply inline-flex items-center px-2.5 py-1 rounded-full bg-sage-light text-sage-dark text-xs font-medium;
  }
</style>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
  const cards = document.querySelectorAll<HTMLElement>('#class-grid .class-card');
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.remove('on'));
      chip.classList.add('on');
      const f = chip.dataset.filter;
      cards.forEach((card) => {
        card.style.display = f === 'all' || card.dataset.cat === f ? '' : 'none';
      });
    });
  });
</script>
