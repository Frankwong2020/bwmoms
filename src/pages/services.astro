---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import ItemFeedback from '../components/ItemFeedback.astro';
import ItemActions from '../components/ItemActions.astro';
import servicesData from '../data/services.json';

type Review = { date: string; text: string };
type Service = {
  id: string;
  category: string;
  name: string;
  phone: string;
  website: string;
  reviews: Review[];
};
const services = servicesData as Service[];
const categories = [...new Set(services.map((s) => s.category).filter(Boolean))];

function telLink(phone: string) {
  const clean = phone.replace(/[^\d+]/g, '');
  return clean ? `tel:${clean}` : null;
}
function isUrl(s: string) {
  return /^https?:\/\//.test(s);
}
---

<Base title="维修师傅推荐 · 桥水小娃群">
  <Header activeTab="services" />

  <section class="max-w-6xl mx-auto px-6 pt-10 pb-6">
    <div class="flex items-start justify-between gap-3 flex-wrap">
      <div>
        <h1 class="text-3xl md:text-4xl font-serif font-bold">🔧 维修师傅 & 服务</h1>
        <p class="text-ink-light mt-2">空调暖气、水电、搬家、清洁、园艺等</p>
      </div>
      <button
        type="button"
        data-create-item
        data-item-type="service"
        class="text-sm px-3 py-1.5 rounded-chip bg-sage text-white hover:bg-sage-dark font-medium whitespace-nowrap mt-2"
      >
        + 新增师傅
      </button>
    </div>
  </section>

  <main class="max-w-6xl mx-auto px-6 pb-16">
    <div class="flex gap-2 overflow-x-auto scrollbar-none mb-6 pb-2">
      <button class="filter-chip on" data-filter="all">全部 ({services.length})</button>
      {categories.map((cat) => (
        <button class="filter-chip" data-filter={cat}>{cat}</button>
      ))}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4" id="svc-grid">
      {services.map((s) => (
        <article
          class="svc-card bg-white rounded-card shadow-soft p-5"
          data-item-card
          data-item-type="service"
          data-item-id={s.id}
          data-cat={s.category}
        >
          <div class="flex items-baseline justify-between gap-2 mb-2">
            <h3 class="font-semibold text-ink text-lg leading-tight" data-field="name">{s.name}</h3>
            <span class="tag shrink-0" data-field="category">{s.category}</span>
          </div>
          <div class="text-sm text-ink-light space-y-1 mb-3">
            <p class:list={{ 'hidden': !s.phone }}>
              📞 <span data-field="phone">{s.phone}</span>
            </p>
            <p class:list={['truncate', { 'hidden': !s.website }]}>
              🌐 <span data-field="website">{s.website}</span>
            </p>
          </div>
          {s.reviews.length > 0 && (
            <details class="mt-3">
              <summary class="text-sm text-sage-dark font-medium cursor-pointer select-none">
                {s.reviews.length} 条群友反馈
              </summary>
              <div class="mt-3 space-y-3">
                {s.reviews.map((r) => (
                  <div class="text-sm border-l-2 border-sage-light pl-3 py-1">
                    {r.date && <div class="text-xs text-ink-muted mb-1">{r.date}</div>}
                    {r.text && <p class="text-ink-light leading-relaxed whitespace-pre-wrap">{r.text}</p>}
                  </div>
                ))}
              </div>
            </details>
          )}
          <ItemActions itemType="service" itemId={s.id} />
          <ItemFeedback itemType="service" itemId={s.id} />
        </article>
      ))}
    </div>
  </main>
</Base>

<script>
  import '../lib/feedback';
  import { registerServiceTemplate } from '../lib/card-templates';
  registerServiceTemplate();
  import '../lib/hydrate-items';
  import '../lib/edit-item';
  import '../lib/history';
  import '../lib/flag';
</script>

<style>
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { scrollbar-width: none; }
  .filter-chip {
    @apply flex-shrink-0 px-4 py-2 rounded-chip text-sm font-medium whitespace-nowrap transition cursor-pointer;
    @apply bg-white text-ink-light hover:bg-sage-light;
  }
  .filter-chip.on {
    @apply bg-sage text-white shadow-soft;
  }
  .tag {
    @apply inline-flex items-center px-2.5 py-1 rounded-full bg-sage-light text-sage-dark text-xs font-medium;
  }
</style>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
  const cards = document.querySelectorAll<HTMLElement>('#svc-grid .svc-card');
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.remove('on'));
      chip.classList.add('on');
      const f = chip.dataset.filter;
      cards.forEach((card) => {
        card.style.display = f === 'all' || card.dataset.cat === f ? '' : 'none';
      });
    });
  });
</script>
