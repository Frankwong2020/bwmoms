---
// Global flag (report) modal. Used for items, comments, ratings.
---

<div
  id="flag-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="flag-title"
>
  <div class="bg-cream rounded-card shadow-hover max-w-lg w-full">
    <div class="border-b border-black/5 px-6 py-4 flex items-center justify-between">
      <h2 id="flag-title" class="font-serif font-bold text-lg">🚩 举报内容</h2>
      <button
        type="button"
        id="flag-close"
        class="text-ink-muted hover:text-ink text-2xl leading-none w-8 h-8 rounded-full hover:bg-sage-light flex items-center justify-center"
        aria-label="关闭"
      >
        ×
      </button>
    </div>

    <form id="flag-form" class="p-6 space-y-4">
      <p class="text-sm text-ink-light">
        感谢你维护社区质量。任何内容被 3 人举报会自动隐藏等待管理员审核。
      </p>

      <div>
        <label class="block text-xs text-ink-muted mb-2 font-medium">举报原因 *</label>
        <div class="space-y-2">
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="radio" name="reason" value="spam" required />
            <span>广告/垃圾信息</span>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="radio" name="reason" value="wrong" />
            <span>信息错误/过时</span>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="radio" name="reason" value="malicious" />
            <span>恶意篡改</span>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="radio" name="reason" value="offensive" />
            <span>冒犯/不当内容</span>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="radio" name="reason" value="other" />
            <span>其他</span>
          </label>
        </div>
      </div>

      <div>
        <label class="block text-xs text-ink-muted mb-1 font-medium">说明（可选）</label>
        <textarea
          name="detail"
          rows="3"
          maxlength="500"
          placeholder="补充说明（管理员审核时参考）"
          class="w-full px-3 py-2 text-sm border border-black/10 rounded-chip focus:outline-none focus:border-sage resize-y"
        ></textarea>
      </div>

      <p id="flag-error" class="hidden text-sm text-warm"></p>

      <div class="flex justify-end gap-2 pt-2">
        <button
          type="button"
          id="flag-cancel"
          class="px-4 py-2 rounded-chip bg-white border border-black/10 text-sm hover:bg-sage-light"
        >
          取消
        </button>
        <button
          type="submit"
          id="flag-submit"
          class="px-4 py-2 rounded-chip bg-warm text-white text-sm font-medium hover:opacity-90 disabled:opacity-50"
        >
          提交举报
        </button>
      </div>
    </form>
  </div>
</div>
