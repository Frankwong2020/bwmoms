---
// Modal for showing edit history of an item. One instance per page.
---

<div
  id="item-history"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="history-title"
>
  <div class="bg-cream rounded-card shadow-hover max-w-3xl w-full max-h-[90vh] overflow-y-auto">
    <div class="sticky top-0 bg-cream/95 backdrop-blur border-b border-black/5 px-6 py-4 flex items-center justify-between">
      <h2 id="history-title" class="font-serif font-bold text-lg">📜 编辑历史</h2>
      <button
        type="button"
        id="history-close"
        class="text-ink-muted hover:text-ink text-2xl leading-none w-8 h-8 rounded-full hover:bg-sage-light flex items-center justify-center"
        aria-label="关闭"
      >
        ×
      </button>
    </div>
    <div id="history-list" class="p-6 space-y-4">
      <p class="text-sm text-ink-muted">加载中…</p>
    </div>
  </div>
</div>
