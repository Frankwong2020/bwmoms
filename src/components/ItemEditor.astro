---
// Global modal container for editing any item. One instance per page.
// Shows/hides based on `data-editor-open` attribute set by edit-item.ts.
---

<div
  id="item-editor"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="editor-title"
>
  <div class="bg-cream rounded-card shadow-hover max-w-2xl w-full max-h-[90vh] overflow-y-auto">
    <div class="sticky top-0 bg-cream/95 backdrop-blur border-b border-black/5 px-6 py-4 flex items-center justify-between">
      <h2 id="editor-title" class="font-serif font-bold text-lg">编辑条目</h2>
      <button
        type="button"
        id="editor-close"
        class="text-ink-muted hover:text-ink text-2xl leading-none w-8 h-8 rounded-full hover:bg-sage-light flex items-center justify-center"
        aria-label="关闭"
      >
        ×
      </button>
    </div>

    <form id="editor-form" class="p-6 space-y-4">
      <div id="editor-fields" class="space-y-4">
        <!-- Fields rendered dynamically by edit-item.ts based on item type -->
      </div>

      <div class="pt-3 border-t border-black/5">
        <label class="block text-xs text-ink-muted mb-1 font-medium">
          编辑说明 <span class="text-warm">（必填，简短说明你为什么改）</span>
        </label>
        <input
          type="text"
          name="edit_comment"
          maxlength="200"
          required
          placeholder="例：修正电话号码、店铺已搬家、地址更新..."
          class="w-full px-3 py-2 text-sm border border-black/10 rounded-chip focus:outline-none focus:border-sage"
        />
      </div>

      <div class="flex items-center justify-between pt-2">
        <a
          id="editor-history-link"
          href="#"
          class="text-xs text-sage-dark hover:text-sage font-medium"
        >📜 查看历史版本</a>
        <div class="flex gap-2">
          <button
            type="button"
            id="editor-cancel"
            class="px-4 py-2 rounded-chip bg-white border border-black/10 text-sm hover:bg-sage-light"
          >
            取消
          </button>
          <button
            type="submit"
            id="editor-submit"
            class="px-4 py-2 rounded-chip bg-sage text-white text-sm font-medium hover:bg-sage-dark disabled:opacity-50"
          >
            保存
          </button>
        </div>
      </div>

      <p id="editor-error" class="hidden text-sm text-warm"></p>
    </form>
  </div>
</div>
